# Optional Gemini support
GEMINI_API_KEY="MY_GEMINI_API_KEY"
GEMINI_MODEL="gemini-1.5-flash"

# SmartLibrary multi-agent model suite for api/transform.ts
# Set these in Vercel Project Settings > Environment Variables.
# auto tries Groq first, then OpenRouter, then Gemini, then local fallback.
SMARTLIBRARY_AI_PROVIDER="auto"

# Groq Cloud
GROQ_API_KEY="YOUR_GROQ_API_KEY"
GROQ_MODEL="llama-3.1-8b-instant"

# OpenRouter
OPENROUTER_API_KEY="YOUR_OPENROUTER_API_KEY"
OPENROUTER_MODEL="meta-llama/llama-3.1-8b-instruct:free"
OPENROUTER_SITE_URL="https://smartlibrary-content-engine.vercel.app"

# Optional OpenAI-compatible premium fallback
OPENAI_API_KEY="YOUR_OPENAI_API_KEY"
OPENAI_MODEL="gpt-4o-mini"

# App URL
APP_URL="https://smartlibrary-content-engine.vercel.app"
